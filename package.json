{
  "name": "studio-website",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./assets/css/site.css --minify",
    "watch:css": "tailwindcss -i ./src/tailwind.css -o ./assets/css/site.css --watch",
    "dev": "concurrently -k \"npm run watch:css\" \"bundle exec jekyll serve --livereload --host 127.0.0.1\""
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
